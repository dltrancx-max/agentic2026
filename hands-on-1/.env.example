# Copy to .env and fill in for LIVE mode (Claude-driven worker).
# Mock mode does NOT require an API key.
ANTHROPIC_API_KEY=

# Optional overrides
LEGACY_HOST=127.0.0.1
LEGACY_PORT=5000
LEGACY_USER=analyst
LEGACY_PASS=legacy123
# Inject one Session Timeout after this many protected actions (0 = off).
LEGACY_TIMEOUT_AFTER=3
TARGET_QUARTER=Q3
